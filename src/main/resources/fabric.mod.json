    ],
    "stationapi:event_bus_server": [
    ],
    "unitweaks:event_bus": [
      "com.periut.retrosprint.UnitweaksFOVCompat"
    ]
  },
  "mixins": [
    "retrosprint.mixins.json"
  ],

  "depends": {
    "minecraft": "1.0.0-beta.7.3"
  }
}
