{
  "schemaVersion": 1,
  "id": "retrosprint",
  "version": "${version}",

  "name": "Retro Sprint",
  "description": "Adds sprinting to b1.7.3",
  "authors": [
    "Slainlight"
  ],

  "license": "MIT",
  "icon": "assets/retrosprint/icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "com.periut.retrosprint.BabricSprint"
    ],
    "stationapi:event_bus": [
    ],
